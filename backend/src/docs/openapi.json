{
  "openapi": "3.1.0",
  "info": {
    "title": "BeatRoute API",
    "version": "1.0.0",
    "description": "API for Spotify and Last.fm authentication, user data and playlists"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3000"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Spotify authentication flow"
    },
    {
      "name": "Session",
      "description": "Application session endpoints"
    },
    {
      "name": "Me",
      "description": "Endpoints for the currently logged-in user"
    },
    {
      "name": "Tracks",
      "description": "Track audio features and aggregate audio statistics"
    },
    {
      "name": "Last.fm",
      "description": "Last.fm account connection and user data"
    }
  ],
  "paths": {
    "/auth/spotify/login": {
      "get": {
        "tags": ["Auth"],
        "summary": "Redirect user to Spotify login",
        "responses": {
          "302": {
            "description": "Redirect to Spotify authorization page"
          }
        }
      }
    },
    "/auth/spotify/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "Handle Spotify OAuth callback",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "error",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect back to frontend"
          },
          "400": {
            "description": "OAuth error or state mismatch"
          }
        }
      }
    },
    "/auth/lastfm/login": {
      "get": {
        "tags": ["Last.fm"],
        "summary": "Redirect user to Last.fm authorization",
        "responses": {
          "302": {
            "description": "Redirect to the Last.fm authorization page"
          },
          "503": {
            "description": "Last.fm integration is not configured"
          }
        }
      }
    },
    "/auth/lastfm/callback": {
      "get": {
        "tags": ["Last.fm"],
        "summary": "Exchange a Last.fm authorization token for a session",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Last.fm session saved and user redirected to frontend"
          },
          "400": {
            "description": "Missing callback parameters or state mismatch"
          },
          "502": {
            "description": "Last.fm session could not be created"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Session"],
        "summary": "Check if user is logged in",
        "responses": {
          "200": {
            "description": "Authentication status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isLoggedIn": {
                      "type": "boolean"
                    }
                  },
                  "required": ["isLoggedIn"]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Session"],
        "summary": "Log out current user",
        "responses": {
          "200": {
            "description": "Logged out successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/lastfm": {
      "get": {
        "tags": ["Last.fm"],
        "summary": "Get Last.fm connection status",
        "responses": {
          "200": {
            "description": "Last.fm connection status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "isConnected": {
                      "type": "boolean"
                    },
                    "username": {
                      "type": ["string", "null"]
                    }
                  },
                  "required": ["isConnected", "username"]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/lastfm/logout": {
      "post": {
        "tags": ["Last.fm"],
        "summary": "Disconnect the Last.fm account",
        "responses": {
          "200": {
            "description": "Last.fm account disconnected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "500": {
            "description": "Application session could not be updated"
          }
        }
      }
    },
    "/api/me/profile": {
      "get": {
        "tags": ["Me"],
        "summary": "Get current Spotify user profile",
        "responses": {
          "200": {
            "description": "Spotify user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpotifyUserProfile"
                }
              }
            }
          },
          "401": {
            "description": "User not logged in"
          }
        }
      }
    },
    "/api/me/top-tracks": {
      "get": {
        "tags": ["Me"],
        "summary": "Get current user's top tracks",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 40,
              "default": 10
            }
          },
          {
            "name": "time_range",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["short_term", "medium_term", "long_term"],
              "default": "medium_term"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top tracks list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TopTracksResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid limit or time range"
          },
          "401": {
            "description": "User not logged in"
          }
        }
      }
    },
    "/api/me/top-artists": {
      "get": {
        "tags": ["Me"],
        "summary": "Get current user's top artists",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 40,
              "default": 10
            }
          },
          {
            "name": "time_range",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["short_term", "medium_term", "long_term"],
              "default": "medium_term"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top artists list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TopArtistsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid limit or time range"
          },
          "401": {
            "description": "User not logged in"
          }
        }
      }
    },
    "/api/tracks/{spotifyTrackId}/audio-features": {
      "get": {
        "tags": ["Tracks"],
        "summary": "Get Soundcharts audio features for a Spotify track",
        "parameters": [
          {
            "$ref": "#/components/parameters/SpotifyTrackId"
          }
        ],
        "responses": {
          "200": {
            "description": "Audio features for the supplied Spotify track",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AudioFeatures"
                }
              }
            }
          },
          "500": {
            "description": "Soundcharts request failed"
          }
        }
      }
    },
    "/api/tracks/audio-features": {
      "post": {
        "tags": ["Tracks"],
        "summary": "Get ReccoBeats audio features for Spotify tracks",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackIdsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audio features for the supplied Spotify tracks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MultipleAudioFeaturesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid trackIds request body"
          },
          "500": {
            "description": "ReccoBeats request failed"
          }
        }
      }
    },
    "/api/tracks/audio-stats": {
      "post": {
        "tags": ["Tracks"],
        "summary": "Calculate aggregate audio statistics for Spotify tracks",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackIdsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aggregate audio statistics for the supplied Spotify tracks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AudioStats"
                }
              }
            }
          },
          "400": {
            "description": "Invalid trackIds request body"
          },
          "500": {
            "description": "ReccoBeats request failed"
          }
        }
      }
    },
    "/api/lastfm/me": {
      "get": {
        "tags": ["Last.fm"],
        "summary": "Get the connected Last.fm user profile",
        "responses": {
          "200": {
            "description": "Last.fm user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LastfmUserProfile"
                }
              }
            }
          },
          "401": {
            "description": "Last.fm account is not connected"
          },
          "502": {
            "description": "Last.fm profile could not be fetched"
          }
        }
      }
    },
    "/api/lastfm/track-info": {
      "get": {
        "tags": ["Last.fm"],
        "summary": "Get track metadata and genre candidates from Last.fm top tags",
        "parameters": [
          {
            "name": "artist",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "track",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mbid",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Track metadata with Last.fm top tags",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LastfmTrackInfo"
                }
              }
            }
          },
          "400": {
            "description": "Neither MBID nor artist and track were provided"
          },
          "502": {
            "description": "Last.fm request failed"
          }
        }
      }
    },
    "/api/lastfm/artist-genres": {
      "post": {
        "tags": ["Last.fm"],
        "summary": "Build a genre distribution for Spotify top artists using Last.fm tags",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "artists": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 40,
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": ["artists"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Genre distribution among the supplied artists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtistGenreDistributionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid artist list"
          },
          "401": {
            "description": "Spotify session is missing or expired"
          },
          "502": {
            "description": "Last.fm request failed"
          }
        }
      }
    },
    "/api/lastfm/spotify-tracks/{spotifyTrackId}": {
      "get": {
        "tags": ["Last.fm"],
        "summary": "Resolve Spotify track metadata and Last.fm genre candidates",
        "parameters": [
          {
            "$ref": "#/components/parameters/SpotifyTrackId"
          }
        ],
        "responses": {
          "200": {
            "description": "Spotify metadata and Last.fm track information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpotifyLastfmTrackResponse"
                }
              }
            }
          },
          "401": {
            "description": "Spotify session is missing or expired"
          },
          "502": {
            "description": "Last.fm request failed"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "SpotifyTrackId": {
        "name": "spotifyTrackId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": ["message"]
      },
      "SpotifyExternalUrls": {
        "type": "object",
        "properties": {
          "spotify": {
            "type": "string"
          }
        },
        "required": ["spotify"]
      },
      "SpotifyImage": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "height": {
            "type": ["integer", "null"]
          },
          "width": {
            "type": ["integer", "null"]
          }
        },
        "required": ["url", "height", "width"]
      },
      "SpotifyFollowers": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["total"]
      },
      "SpotifyUserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "display_name": {
            "type": ["string", "null"]
          },
          "email": {
            "type": ["string", "null"]
          },
          "country": {
            "type": ["string", "null"]
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpotifyImage"
            }
          },
          "external_urls": {
            "$ref": "#/components/schemas/SpotifyExternalUrls"
          },
          "followers": {
            "$ref": "#/components/schemas/SpotifyFollowers"
          },
          "href": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          }
        },
        "required": ["id"]
      },
      "SpotifyTopArtist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "genres": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpotifyImage"
            }
          },
          "followers": {
            "$ref": "#/components/schemas/SpotifyFollowers"
          },
          "popularity": {
            "type": "integer"
          },
          "external_urls": {
            "$ref": "#/components/schemas/SpotifyExternalUrls"
          }
        },
        "required": [
          "id",
          "name",
          "genres",
          "images",
          "followers",
          "popularity",
          "external_urls"
        ]
      },
      "SpotifyTrackArtist": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": ["name"]
      },
      "SpotifyAlbumSummary": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpotifyImage"
            }
          }
        },
        "required": ["name", "images"]
      },
      "SpotifyTopTrack": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "artists": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpotifyTrackArtist"
            }
          },
          "album": {
            "$ref": "#/components/schemas/SpotifyAlbumSummary"
          },
          "duration_ms": {
            "type": "integer"
          },
          "popularity": {
            "type": "integer"
          }
        },
        "required": ["id", "name", "artists", "album", "duration_ms", "popularity"]
      },
      "SpotifyPagingBase": {
        "type": "object",
        "properties": {
          "href": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          },
          "next": {
            "type": ["string", "null"]
          },
          "offset": {
            "type": "integer"
          },
          "previous": {
            "type": ["string", "null"]
          },
          "total": {
            "type": "integer"
          }
        },
        "required": ["href", "limit", "next", "offset", "previous", "total"]
      },
      "TopTracksResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SpotifyPagingBase"
          },
          {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SpotifyTopTrack"
                }
              }
            },
            "required": ["items"]
          }
        ]
      },
      "TopArtistsResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SpotifyPagingBase"
          },
          {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SpotifyTopArtist"
                }
              }
            },
            "required": ["items"]
          }
        ]
      },
      "TrackIdsRequest": {
        "type": "object",
        "properties": {
          "trackIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 40,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["trackIds"]
      },
      "AudioFeatures": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "spotifyId": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "acousticness": {
            "type": ["number", "null"]
          },
          "danceability": {
            "type": ["number", "null"]
          },
          "energy": {
            "type": ["number", "null"]
          },
          "instrumentalness": {
            "type": ["number", "null"]
          },
          "key": {
            "type": ["integer", "null"]
          },
          "liveness": {
            "type": ["number", "null"]
          },
          "loudness": {
            "type": ["number", "null"]
          },
          "mode": {
            "type": ["integer", "null"]
          },
          "speechiness": {
            "type": ["number", "null"]
          },
          "tempo": {
            "type": ["number", "null"]
          },
          "timeSignature": {
            "type": ["integer", "null"]
          },
          "valence": {
            "type": ["number", "null"]
          },
          "error": {
            "type": "string"
          }
        }
      },
      "MultipleAudioFeaturesResponse": {
        "type": "object",
        "properties": {
          "audio_features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AudioFeatures"
            }
          }
        },
        "required": ["audio_features"]
      },
      "AudioStats": {
        "type": "object",
        "properties": {
          "trackCount": {
            "type": "integer",
            "minimum": 0
          },
          "averageBpm": {
            "type": ["number", "null"]
          },
          "averageEnergy": {
            "type": ["number", "null"]
          },
          "averageDanceability": {
            "type": ["number", "null"]
          },
          "averageValence": {
            "type": ["number", "null"]
          },
          "averageAcousticness": {
            "type": ["number", "null"]
          },
          "averageInstrumentalness": {
            "type": ["number", "null"]
          },
          "averageLiveness": {
            "type": ["number", "null"]
          },
          "averageSpeechiness": {
            "type": ["number", "null"]
          },
          "averageLoudness": {
            "type": ["number", "null"]
          },
          "dominantKey": {
            "type": ["integer", "null"]
          },
          "dominantMode": {
            "type": ["integer", "null"]
          },
          "majorPercentage": {
            "type": "number",
            "minimum": 0
          },
          "minorPercentage": {
            "type": "number",
            "minimum": 0
          },
          "dominantTimeSignature": {
            "type": ["integer", "null"]
          },
          "liveTrackPercentage": {
            "type": "number",
            "minimum": 0
          },
          "instrumentalTrackPercentage": {
            "type": "number",
            "minimum": 0
          },
          "speechHeavyTrackPercentage": {
            "type": "number",
            "minimum": 0
          },
          "foundTracksCount": {
            "type": "integer",
            "minimum": 0
          },
          "totalTracksCount": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "trackCount",
          "averageBpm",
          "averageEnergy",
          "averageDanceability",
          "averageValence",
          "averageAcousticness",
          "averageInstrumentalness",
          "averageLiveness",
          "averageSpeechiness",
          "averageLoudness",
          "dominantKey",
          "dominantMode",
          "majorPercentage",
          "minorPercentage",
          "dominantTimeSignature",
          "liveTrackPercentage",
          "instrumentalTrackPercentage",
          "speechHeavyTrackPercentage",
          "foundTracksCount",
          "totalTracksCount"
        ]
      },
      "LastfmUserProfile": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "realname": {
            "type": ["string", "null"]
          },
          "url": {
            "type": ["string", "null"]
          },
          "image": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "#text": {
                  "type": "string"
                },
                "size": {
                  "type": "string"
                }
              },
              "required": ["#text", "size"]
            }
          },
          "playcount": {
            "type": ["string", "null"]
          },
          "registered": {
            "type": "object",
            "properties": {
              "unixtime": {
                "type": "string"
              },
              "#text": {
                "type": "integer"
              }
            }
          },
          "country": {
            "type": ["string", "null"]
          }
        },
        "required": ["name"]
      },
      "LastfmTrackInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": ["string", "null"]
          },
          "artist": {
            "type": ["string", "null"]
          },
          "mbid": {
            "type": ["string", "null"]
          },
          "url": {
            "type": ["string", "null"]
          },
          "genre": {
            "type": ["string", "null"],
            "description": "First Last.fm top tag; it is not an authoritative genre"
          },
          "genreCandidates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "url": {
                  "type": ["string", "null"]
                }
              },
              "required": ["name", "url"]
            }
          },
          "genreSource": {
            "type": ["string", "null"],
            "enum": [
              "lastfm-top-tags",
              "lastfm-track-top-tags",
              "lastfm-artist-info-tags",
              null
            ]
          },
          "genreIsFallback": {
            "type": "boolean",
            "description": "True when tags come from the artist instead of the track"
          }
        },
        "required": [
          "name",
          "artist",
          "mbid",
          "url",
          "genre",
          "genreCandidates",
          "tags",
          "genreSource",
          "genreIsFallback"
        ]
      },
      "SpotifyTrackSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "album": {
            "type": ["string", "null"]
          },
          "durationMs": {
            "type": ["integer", "null"]
          },
          "spotifyUrl": {
            "type": ["string", "null"]
          }
        },
        "required": ["id", "name", "artists", "album", "durationMs", "spotifyUrl"]
      },
      "SpotifyLastfmTrackResponse": {
        "type": "object",
        "properties": {
          "spotify": {
            "$ref": "#/components/schemas/SpotifyTrackSummary"
          },
          "lastfm": {
            "$ref": "#/components/schemas/LastfmTrackInfo"
          }
        },
        "required": ["spotify", "lastfm"]
      },
      "ArtistGenreDistributionSubgenreItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "percentage": {
            "type": "number",
            "minimum": 0
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["name", "count", "percentage", "artists"]
      },
      "ArtistGenreDistributionItem": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtistGenreDistributionSubgenreItem"
          },
          {
            "type": "object",
            "properties": {
              "subgenres": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ArtistGenreDistributionSubgenreItem"
                }
              }
            },
            "required": ["subgenres"]
          }
        ]
      },
      "ArtistGenreDistributionResponse": {
        "type": "object",
        "properties": {
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArtistGenreDistributionItem"
            }
          },
          "totalArtists": {
            "type": "integer",
            "minimum": 0
          },
          "matchedArtists": {
            "type": "integer",
            "minimum": 0
          },
          "totalGenreMatches": {
            "type": "integer",
            "minimum": 0
          },
          "unmatchedArtists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string",
            "enum": ["lastfm-artist-info-tags"]
          }
        },
        "required": [
